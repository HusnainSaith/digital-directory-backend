# =======================================================
# Digital Business Directory — Environment Configuration
# =======================================================

# ── General ────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database (PostgreSQL) ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_DATABASE=business_directory
TYPEORM_LOGGING=false

# ── JWT ────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_change_me
JWT_EXPIRES_IN=15m

# ── CORS / Frontend ───────────────────────────────────
# Comma-separated list of allowed origins
FRONTEND_URLS=http://localhost:3000,https://labverse.org,https://www.labverse.org

# ── Throttle / Rate Limiting ──────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PRICE_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_YEARLY=price_xxxxxxxxxxxx

# ── Cloudflare R2 (S3-compatible) ─────────────────────

R2_ACCESS_KEY_ID=f27e8e9d6159027bc581664ce6831cb1
R2_SECRET_ACCESS_KEY=6d1f1f8aeb6bd72a327a7a04f31423f3fb5143c80c965af4b97570b44dc64b73
R2_ENDPOINT=https://b154a49ac214214f5916e1853f19760a.r2.cloudflarestorage.com
R2_BUCKET_NAME=zaroox
R2_PUBLIC_URL=https://pub-65f61885e6a4489e8cf9e0f61e13c811.r2.dev

# R2_ENDPOINT is auto-derived from ACCOUNT_ID:
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# ── SMTP / Mailer ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM_NAME=Business Directory
MAIL_FROM_EMAIL=noreply@labverse.org
